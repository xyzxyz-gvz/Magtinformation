{"id": 7262, "nummer": 77, "vedtaget": false, "typeid": 3, "type": "Forslag til vedtagelse", "dato": "2019-12-18", "mødeid": 9648, "sagstrinid": 207478, "konklusion": "Forslaget blev forkastet. For stemte 51 (V, DF, KF, NB og LA), imod stemte 61 (S, RV, SF, EL og ALT), hverken for eller imod stemte 0.", "kommentar": "", "forCount": 51, "imodCount": 61, "fraværCount": 67, "hverkenCount": 0, "caseTitel": "Folketinget finder det foruroligende, at regeringen og den øvrige venstrefløj har valgt at hæve ydelserne særligt til arbejdsløse indvandrere og flygtninge. Folketinget konstaterer, at størrelsen på de sociale ydelser har en effekt på asyltilstrømningen, og finder det derfor dybt uansvarligt at bruge 300 millioner skattekroner på at hæve de sociale ydelser. Folketinget ser med stor bekymring på, at en øget tilstrømning vil medføre yderligere problemer med kriminalitet, religiøs funderet radikalisering, arbejdsløshed, parallelsamfund m.v. Folketinget opfordrer derfor regeringen til at tilbagerulle denne lempelse af udlændingepolitikken og i stedet fremlægge konkrete forslag til at dæmme op for asyltilstrømningen.", "caseNummer": "V 29", "caseUrl": null, "stemmer": [{"aktørid": 152, "typeid": 2}, {"aktørid": 50, "typeid": 1}, {"aktørid": 220, "typeid": 2}, {"aktørid": 183, "typeid": 1}, {"aktørid": 184, "typeid": 2}, {"aktørid": 121, "typeid": 2}, {"aktørid": 93, "typeid": 1}, {"aktørid": 120, "typeid": 2}, {"aktørid": 34, "typeid": 1}, {"aktørid": 246, "typeid": 2}, {"aktørid": 67, "typeid": 2}, {"aktørid": 199, "typeid": 2}, {"aktørid": 1454, "typeid": 1}, {"aktørid": 55, "typeid": 2}, {"aktørid": 173, "typeid": 1}, {"aktørid": 260, "typeid": 2}, {"aktørid": 178, "typeid": 1}, {"aktørid": 180, "typeid": 1}, {"aktørid": 201, "typeid": 2}, {"aktørid": 668, "typeid": 1}, {"aktørid": 38, "typeid": 2}, {"aktørid": 257, "typeid": 2}, {"aktørid": 217, "typeid": 1}, {"aktørid": 130, "typeid": 1}, {"aktørid": 163, "typeid": 1}, {"aktørid": 80, "typeid": 1}, {"aktørid": 97, "t